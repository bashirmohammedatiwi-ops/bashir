# Copy to .env and fill values before deploy
DOMAIN=187.127.88.146
CERTBOT_EMAIL=admin@example.com

POSTGRES_USER=alhayaa
POSTGRES_PASSWORD=change_me_strong_postgres_password
POSTGRES_DB=alhayaa

JWT_ACCESS_SECRET=change_me_long_random_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_long_random_refresh_secret_min_32_chars

ADMIN_EMAIL=admin@alhayaa.com
ADMIN_PASSWORD=ChangeMeStrongAdminPassword

CORS_ORIGIN=*

# Media URL — for IP-only use http://YOUR_IP/media
MEDIA_PUBLIC_BASE_URL=http://187.127.88.146/media

# 1 = أنشئ/حدّث حساب الأدمن فقط عند إقلاع الـ API (بدون براندات/منتجات تجريبية)
# اتركه 0 بعد أول نشر — أو استخدم: ./scripts/reset-admin.sh
RUN_SEED=0

# لا تفعّل على الإنتاج — يضيف براندات/منتجات/عملاء تجريبيين (MAC, Dior…)
SEED_DEMO=0

# Media compression (stored on VPS before serving via Nginx)
MEDIA_MAX_FILE_SIZE_MB=15
MEDIA_MAX_ORIGINAL_WIDTH=2400
MEDIA_WEBP_QUALITY=90
MEDIA_JPEG_QUALITY=90
MEDIA_AVIF_QUALITY=62

THROTTLE_LIMIT=300

HOME_FEED_CACHE_TTL_SEC=90
# SENTRY_DSN=
DISK_WARN_PERCENT=85

# ── Amazon Beauty ───────────────────────────────────────────
# اختياري — بدون مفاتيح يعمل الجلب عبر صفحات Amazon.
# مع مفاتيح PA-API أكثر استقراراً (Associates Central).
# AMAZON_ACCESS_KEY=
# AMAZON_SECRET_KEY=
# AMAZON_PARTNER_TAG=
# AMAZON_AUTO_CRAWL=0
