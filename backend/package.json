{
  "name": "backend",
  "version": "1.0.0",
  "description": "Alhayaa commerce backend (NestJS + Fastify)",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --ignore-watch node_modules src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "npx tsx prisma/seed.ts",
    "import:niceone-categories": "npx tsx prisma/import-niceone-categories.ts",
    "backfill:images": "node scripts/backfill-product-images.js"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "keywords": [
    "nestjs",
    "commerce",
    "alhayaa"
  ],
  "author": "alhayaa",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.21",
    "@nestjs/swagger": "^11.4.3",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.10",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "fastify": "^5.8.5",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.1.0",
    "iconv-lite": "^0.6.3",
    "ioredis": "^5.10.1",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "tsx": "^4.22.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
