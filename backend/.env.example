# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*
# Or restrict: http://localhost:3001,http://localhost:5173,http://localhost:8080

# Database (PostgreSQL — use Docker: infra/docker-compose.yml)
DATABASE_URL=postgresql://alhayaa:alhayaa@localhost:5432/alhayaa?schema=public

# Redis (set REDIS_DISABLED=1 for local dev without Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_DISABLED=1

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_long_random
JWT_REFRESH_SECRET=change_me_refresh_secret_long_random
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Media — compressed before storage (WebP + JPEG on disk)
MEDIA_ROOT=./uploads
MEDIA_PUBLIC_PREFIX=/media
MEDIA_PUBLIC_BASE_URL=http://localhost:3000/media
MEDIA_MAX_FILE_SIZE_MB=15
MEDIA_MAX_ORIGINAL_WIDTH=2400
MEDIA_WEBP_QUALITY=90
MEDIA_JPEG_QUALITY=90
MEDIA_AVIF_QUALITY=62

# Rate limiting (requests per minute per IP)
THROTTLE_LIMIT=200

# Home feed Redis cache (seconds)
HOME_FEED_CACHE_TTL_SEC=90

# Sentry error monitoring (optional — leave empty to disable)
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Disk usage warning threshold for /health/ready (%)
DISK_WARN_PERCENT=85

# Firebase Cloud Messaging (optional — in-app notifications work without this)
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
ADMIN_EMAIL=admin@alhayaa.com
ADMIN_PASSWORD=Admin@12345
