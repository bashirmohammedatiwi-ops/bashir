{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "outDir": "dist-electron",
    "rootDir": "src/main",
    "moduleResolution": "node"
  },
  "include": ["src/main/**/*.ts"]
}
