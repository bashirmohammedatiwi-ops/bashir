# ── Amazon Beauty ───────────────────────────────────────────
# اختياري — بدون مفاتيح يعمل الجلب عبر صفحات Amazon (scrape).
# مع مفاتيح PA-API يكون أكثر استقراراً:
# https://affiliate-program.amazon.com/ → Product Advertising API
# AMAZON_ACCESS_KEY=
# AMAZON_SECRET_KEY=
# AMAZON_PARTNER_TAG=

# اختياري — سوق عربي لأسماء المنتجات بالعربية (مثل amazon.ae)
# AMAZON_MARKETPLACE=www.amazon.com
# AMAZON_MARKETPLACE_AR=www.amazon.ae
# AMAZON_PARTNER_TAG_AR=

# زحف فهرس Beauty — معطّل افتراضياً حتى لا يبطّئ مسواگ
# AMAZON_CRAWL_DELAY_MS=2200
# AMAZON_AUTO_CRAWL=0
